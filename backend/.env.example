# Copy this to .env and adjust for your environment.

# SQLite by default (zero setup). For Postgres:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/india_post
DATABASE_URL=sqlite:///./india_post.db

# Change this in production — used to sign JWTs
SECRET_KEY=change-this-to-a-long-random-string

ACCESS_TOKEN_EXPIRE_MINUTES=480

# Comma-separated list, or * for any origin (dev only)
CORS_ORIGINS=*
